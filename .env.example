# --- Secret de session (JWT) — mettez une longue chaîne aléatoire ---
# Générer : openssl rand -base64 32
AUTH_SECRET=change-me-please

# --- Base de données ---
# En local : laissez vide → un fichier ./local.db est utilisé automatiquement.
# En production (Vercel) : renseignez Turso.
#   turso db create garde-manger
#   turso db show garde-manger --url        → TURSO_DATABASE_URL (libsql://…)
#   turso db tokens create garde-manger     → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Comptes autorisés (jusqu'à 4) ---
# Lancez ensuite : npm run db:setup  (crée le schéma + ces comptes)
USER1_EMAIL=muvikx@gmail.com
USER1_PASSWORD=choisissez-un-mot-de-passe
USER2_EMAIL=sam@gmail.com
USER2_PASSWORD=choisissez-un-mot-de-passe
